# Copy this file to `secrets.yaml` and fill in your own values.
# `secrets.yaml` is gitignored and must never be committed.
#
# AppDaemon resolves `!secret <name>` references in doorman.yaml from this file
# (it lives in the same directory as the app).

# UniFi Protect NVR API key (Settings > Control Plane > Integrations / API key)
# Used to pull the full-resolution doorbell snapshot from the NVR.
nvr_api_key: your-unifi-protect-api-key

# CompreFace recognition API key (the "API Key" of your Recognition service)
compreface_api_key: your-compreface-recognition-api-key

# OpenAI API key (optional; used for the LLM greeting / fallback description)
openai_key: sk-your-openai-key
